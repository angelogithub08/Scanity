# Configurações da Aplicação
APP_PORT=3000
NODE_ENV=production

# Configurações JWT
JWT_SECRET=sua_chave_secreta_jwt_aqui
JWT_TTL=10080m
JWT_REFRESH_TTL=30d

# Configurações do Banco de Dados
DB_CONNECTION_URI=postgresql://usuario:senha@host:porta/database

# Configurações de Email
MAIL_SENDER="Sua Aplicação <naoresponda@suaaplicacao.com.br>"
MAIL_HOST=seu.servidor.smtp.com
MAIL_PORT=587
MAIL_USER=seu_usuario_email
MAIL_PASS=sua_senha_email
MAIL_SECURE=false

# Nome da Plataforma
PLATFORM_NAME=Gerenciador de Processos

# Configurações do AWS S3
# Chave de acesso AWS (obrigatório)
AWS_ID=sua_aws_access_key_id
# Chave secreta AWS (obrigatório)
AWS_SECRET=sua_aws_secret_access_key
# Região do bucket S3 (obrigatório)
AWS_REGION=us-east-1
# Nome do bucket S3 (obrigatório)
AWS_BUCKET=seu-bucket-s3

# Tempo de vida da assinatura S3 em dias
AWS_SIGNATURE_TTL=7

# Configurações do OpenAI (opcionais)
OPENAI_API_KEY=sua_chave_openai_aqui
OPENAI_ORGANIZATION_ID=sua_org_id_openai
OPENAI_PROJECT_ID=seu_project_id_openai
OPENAI_DEFAULT_CHAT_MODEL=gpt-4o-mini
OPENAI_DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_DEFAULT_TEMPERATURE=0.7
OPENAI_DEFAULT_MAX_TOKENS=1000
OPENAI_DEFAULT_TOP_P=1.0
OPENAI_REQUEST_TIMEOUT=30000
OPENAI_RETRY_ATTEMPTS=3
OPENAI_RETRY_DELAY=1000
OPENAI_MAX_REQUESTS_PER_MINUTE=60
OPENAI_MAX_TOKENS_PER_MINUTE=150000
OPENAI_LOG_REQUESTS=true
OPENAI_LOG_RESPONSES=false
OPENAI_LOG_ERRORS=true
