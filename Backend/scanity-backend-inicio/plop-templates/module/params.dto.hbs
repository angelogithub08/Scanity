import { ApiProperty } from '@nestjs/swagger';
import { IsOptional, IsString, IsNumber, IsEmail } from 'class-validator';
import { Type } from 'class-transformer';

export class List{{pascalCase module}}ParamsDto {
{{#each (splitFields fields)}}
  @ApiProperty({
    description: 'Filtrar por {{this.name}}',
    example: {{{this.example}}},
    required: false
  })
  {{#if this.validator}}@{{this.validator}}{{else}}@IsString(){{/if}}
  @IsOptional()
  {{this.name}}?: {{this.type}};

{{/each}}
}

export class ListPaginated{{pascalCase module}}ParamsDto extends List{{pascalCase module}}ParamsDto {
  @ApiProperty({
    description: 'Número da página',
    example: 1,
    minimum: 1,
    default: 1,
    required: false
  })
  @IsNumber()
  @Type(() => Number)
  @IsOptional()
  page?: number;

  @ApiProperty({
    description: 'Limite de registros por página',
    example: 10,
    minimum: 1,
    maximum: 100,
    default: 10,
    required: false
  })
  @IsNumber()
  @Type(() => Number)
  @IsOptional()
  limit?: number;
}