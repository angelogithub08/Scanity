import { Inject, Injectable, Logger, NotFoundException } from '@nestjs/common';
import { Knex } from 'knex';
import { Create{{pascalCase module}}Dto } from './dto/create-{{kebabCase module}}.dto';
import {
  List{{pascalCase module}}ParamsDto,
  ListPaginated{{pascalCase module}}ParamsDto,
} from './dto/params-{{kebabCase module}}.dto';
import { Update{{pascalCase module}}Dto } from './dto/update-{{kebabCase module}}.dto';
import { {{pascalCase singular}} } from './entities/{{kebabCase singular}}.entity';
import { KNEX_CONNECTION } from '../../infra/database/database.providers';

export interface ListParams {
  page?: number;
  limit?: number;
  [key: string]: any; // demais filtros
}

export interface PaginatedResult<T> {
  data: T[];
  total: number;
  page: number;
  last_page: number;
  limit: number;
}

export interface CountResult {
  count: number;
}

@Injectable()
export class {{pascalCase module}}Repository {
  private readonly logger = new Logger({{pascalCase module}}Repository.name);
  private readonly table = '{{snakeCase module}}';
  private readonly defaultSelectFields = [
    'id',
    {{#each (splitFields fields)}}
        '{{snakeCase this.name}}',
    {{/each}}
    'created_at',
    'updated_at',
  ];

  constructor(@Inject(KNEX_CONNECTION) private readonly knex: Knex) {}  

  /** 
   * Constrói o query builder aplicando filtros recebidos. 
   * Não aplica paginação nem seleção de colunas.
   */
  private defaultQuery(filters: Record<string, any> = {}) {
    this.logger.debug(
      `Construindo query com filtros: ${JSON.stringify(filters)}`,
    );
    return this.knex(this.table).modify((qb) => {
      applyDefaultQuery(qb, this.table, filters);
    });
  }

  /**
   * Busca paginada e filtrada usando defaultQuery.
   */
  async findAll(params: ListPaginated{{pascalCase module}}ParamsDto): Promise<PaginatedResult<{{pascalCase singular}}>> {
    const { page = 1, limit = 10, ...filters } = params;
    this.logger.debug(
      `Buscando {{kebabCase module}} paginados: página ${page}, limite ${limit}`,
    );

    try {
      // 1) total de registros (mesmos filtros)
      const result = (await this.defaultQuery(filters)
        .clone()
        .count('* as count')
        .first()) as CountResult;

      const total = Number(result?.count || 0);

      // 2) lista de dados (mesmos filtros + paginação + seleção de campos)
      const offset = (page - 1) * limit;
      const data = (await this.defaultQuery(filters)
        .clone()
        .orderBy('name', 'asc')
        .select(this.defaultSelectFields)
        .limit(limit)
        .offset(offset)) as {{pascalCase singular}}[];

      // 3) calcula última página
      const last_page = limit > 0 ? Math.ceil(total / limit) : 1;

      this.logger.debug(
        `Encontrados ${total} {{kebabCase module}}, ${data.length} na página atual`,
      );
      return { data, total, page: +page, last_page: +last_page, limit: +limit };
    } catch (error) {
      this.logger.error(
        `Erro ao buscar {{kebabCase module}} paginados: ${(error as Error).message}`,
        error instanceof Error ? error.stack : undefined,
      );
      throw error;
    }
  }

  /** Listagem simples (sem paginação), só campos padrão */
  async list(filters: List{{pascalCase module}}ParamsDto): Promise<{{pascalCase singular}}[]> {
    this.logger.debug(
      `Listando todos os {{kebabCase module}} com filtros: ${JSON.stringify(filters)}`,
    );
    try {
      const results = (await this.defaultQuery(filters)
        .clone()
        .select(this.defaultSelectFields)) as {{pascalCase singular}}[];

      this.logger.debug(`Encontrados ${results.length} {{kebabCase module}}`);
      return results;
    } catch (error) {
      this.logger.error(
        `Erro ao listar {{kebabCase module}}: ${(error as Error).message}`,
        error instanceof Error ? error.stack : undefined,
      );
      throw error;
    }
  }

  /** Busca individual, sem paginação */
  async findOne(id: string): Promise<{{pascalCase singular}}> {
    this.logger.debug(`Buscando {{kebabCase singular}} com ID: ${id}`);
    try {
      const record = (await this.defaultQuery({ id })
        .clone()
        .select(this.defaultSelectFields)
        .first()) as {{pascalCase singular}};

      if (!record) {
        this.logger.warn(`{{kebabCase singular}} com ID ${id} não encontrado`);
        throw new NotFoundException(
          `${this.table} com ID ${id} não encontrado`,
        );
      }
      return record;
    } catch (error) {
      this.logger.error(
        `Erro ao buscar {{kebabCase singular}} ${id}: ${(error as Error).message}`,
        error instanceof Error ? error.stack : undefined,
      );
      throw error;
    }
  }

  async create(data: Create{{pascalCase module}}Dto): Promise<{{pascalCase singular}}> {
    this.logger.debug(`Criando novo {{kebabCase singular}}: ${JSON.stringify(data)}`);
    try {
      const [inserted] = (await this.knex(this.table)
        .insert(data)
        .returning(this.defaultSelectFields)) as {{pascalCase singular}}[];

      this.logger.debug(`{{kebabCase singular}} criado com ID: ${inserted.id}`);
      return inserted;
    } catch (error) {
      this.logger.error(
        `Erro ao criar {{kebabCase singular}}: ${(error as Error).message}`,
        error instanceof Error ? error.stack : undefined,
      );
      throw error;
    }
  }

  async update(
    id: string,
    data: Update{{pascalCase module}}Dto,
  ): Promise<{{pascalCase singular}}> {
    this.logger.debug(`Atualizando {{kebabCase singular}} ID ${id}: ${JSON.stringify(data)}`);
    try {
      const count = await this.knex(this.table)
        .where({ id })
        .update({ ...data, updated_at: new Date() });

      if (count === 0) {
        this.logger.warn(
          `{{kebabCase singular}} com ID ${id} não encontrado para atualização`,
        );
        throw new NotFoundException(
          `${this.table} com ID ${id} não encontrado`,
        );
      }
      this.logger.debug(`{{kebabCase singular}} ${id} atualizado com sucesso`);
      return this.findOne(id);
    } catch (error) {
      if (error instanceof NotFoundException) {
        throw error;
      }
      this.logger.error(
        `Erro ao atualizar {{kebabCase singular}} ${id}: ${(error as Error).message}`,
        error instanceof Error ? error.stack : undefined,
      );
      throw error;
    }
  }

  async remove(id: string): Promise<number> {
    this.logger.debug(`Removendo {{kebabCase singular}} com ID: ${id}`);
    try {
      const count = await this.knex(this.table)
        .where({ id })
        .update({ deleted_at: new Date(), updated_at: new Date() });

      if (count === 0) {
        this.logger.warn(
          `{{kebabCase singular}} com ID ${id} não encontrado para remoção`,
        );
        throw new NotFoundException(
          `${this.table} com ID ${id} não encontrado`,
        );
      }
      this.logger.debug(`{{kebabCase singular}} ${id} removido com sucesso`);
      return count;
    } catch (error) {
      if (error instanceof NotFoundException) {
        throw error;
      }
      this.logger.error(
        `Erro ao remover {{kebabCase singular}} ${id}: ${(error as Error).message}`,
        error instanceof Error ? error.stack : undefined,
      );
      throw error;
    }
  }
}
