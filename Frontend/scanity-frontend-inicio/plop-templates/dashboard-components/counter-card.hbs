<template>
  <q-card class="counter-card">
    <q-card-section class="counter-content" :class="gradientClass">
      <div class="text-h6 q-mb-xs counter-title">\{{ title }}</div>
      <div class="text-h4 text-weight-bold counter-value">\{{ value }}</div>
      <div class="icon-container">
        <q-icon :name="icon" :class="['bg-icon', iconColorClass]" />
      </div>
    </q-card-section>
  </q-card>
</template>

<script setup lang="ts">
import { computed } from 'vue';

const props = defineProps<{
  title: string;
  value: number | string;
  icon: string;
}>();

// Cores para diferentes tipos de cards baseados no ícone
const gradientClass = computed(() => {
  const iconMap = {
    shopping_cart: 'gradient-blue',
    payments: 'gradient-green',
    people: 'gradient-purple',
    inventory_2: 'gradient-orange',
  };

  return iconMap[props.icon as keyof typeof iconMap] || 'gradient-default';
});

// Cores para os ícones
const iconColorClass = computed(() => {
  const iconMap = {
    shopping_cart: 'text-blue',
    payments: 'text-green',
    people: 'text-purple',
    inventory_2: 'text-orange',
  };

  return iconMap[props.icon as keyof typeof iconMap] || 'text-grey';
});
</script>

