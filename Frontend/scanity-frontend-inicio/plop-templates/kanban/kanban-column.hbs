  flex: 0 0 auto;
  cursor: move;
  padding: 0.25rem 0.1rem;
  border-radius: 4px;
  transition: background-color 0.2s;
}

.column-header:hover {
  background-color: rgba(0, 0, 0, 0.05);
}

.column-title-edit {
  width: 180px;
  margin-right: 8px;
}

.text-subtitle1 {
  cursor: pointer;
  padding: 4px 0px;
