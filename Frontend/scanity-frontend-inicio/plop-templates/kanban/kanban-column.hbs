<template>
  <div class="kanban-column bg-grey-2 q-pa-md rounded-borders" :data-column-id="column.id">
    <div class="column-header row items-center justify-between q-mb-md column-drag-handle">
      <div class="text-subtitle1 text-weight-bold" v-if="!isEditingColumnTitle" @click="startEditingColumnTitle">
        \{{ column.title }}
      </div>
      <q-input
        v-else
        v-model="editedColumnTitle"
        dense
        outlined
        autofocus
        class="column-title-edit"
        @keyup.enter="saveColumnTitle"
        @blur="saveColumnTitle"
      >
        <template v-slot:append>
          <q-btn round dense flat icon="check" @click="saveColumnTitle" />
        </template>
      </q-input>
      <div class="row items-center">
        <div class="text-caption text-grey-8 q-mr-sm">\{{ column.cards.length }} itens</div>
        <q-icon name="drag_indicator" size="xs" class="cursor-move text-grey-6" />
      </div>
    </div>

    <div class="column-content">
      <div class="cards-container">
        <draggable
          v-model="columnCards"
          :group="{ name: 'cards', pull: true, put: true }"
          item-key="id"
          ghost-class="ghost-card"
          drag-class="drag-card"
          animation="200"
          @end="onDragEnd"
          :empty-insert-threshold="20"
        >
          <template #item="{ element }">
            <kanban-card
              :card="element"
              @open-details="(id) => $emit('open-card-details', id)"
            />
          </template>
          <template #header>
            <div class="empty-zone" v-if="column.cards.length === 0">
              <div class="text-grey text-center q-pa-md">
                Arraste um card para cá
              </div>
            </div>
          </template>
        </draggable>
      </div>

      <q-btn
        outline
        class="full-width q-mt-sm text-grey-6"
        icon="add"
        label="Adicionar"
        @click="$emit('add-card', column.id)"
      />
    </div>
  </div>
</template>

<script setup lang="ts">
import KanbanCard from './KanbanCard.vue';
import type { KanbanColumn } from 'src/interfaces/kanban';
import { computed, ref } from 'vue';
import draggable from 'vuedraggable';

const props = defineProps<{
  column: KanbanColumn;
}>();

const emit = defineEmits<{
  (e: 'open-card-details', cardId: string): void;
  (e: 'add-card', columnId: string): void;
  (e: 'move-card', payload: { cardId: string, fromColumnId: string, toColumnId: string, newIndex: number }): void;
  (e: 'update-column-cards', payload: { columnId: string, cards: any[] }): void;
  (e: 'update-column-title', payload: { columnId: string, title: string }): void;
}>();

// Estado para edição de título da coluna
const isEditingColumnTitle = ref(false);
const editedColumnTitle = ref('');

// Iniciar edição do título da coluna
function startEditingColumnTitle() {
  editedColumnTitle.value = props.column.title;
  isEditingColumnTitle.value = true;
}

// Salvar o novo título da coluna
function saveColumnTitle() {
  const trimmedTitle = editedColumnTitle.value.trim();
  if (trimmedTitle && props.column) {
    // Emitir evento para o componente pai atualizar o título da coluna
    emit('update-column-title', {
      columnId: props.column.id,
      title: trimmedTitle
    });
  }
  isEditingColumnTitle.value = false;
}

// Computed property para manipular os cards da coluna
const columnCards = computed({
  get: () => props.column.cards,
  set: (newCards) => {
    // Quando os cards são reordenados, emitimos um evento com a nova ordenação
    emit('update-column-cards', {
      columnId: props.column.id,
      cards: newCards
    });
  }
});

// Função chamada quando o drag termina
function onDragEnd(evt: any) {
  if (evt.from !== evt.to) {
    // Se o card foi movido para outra coluna
    emit('move-card', {
      cardId: evt.item.getAttribute('data-id'), // ID do card movido
      fromColumnId: evt.from.closest('.kanban-column').getAttribute('data-column-id'), 
      toColumnId: evt.to.closest('.kanban-column').getAttribute('data-column-id'),
      newIndex: evt.newIndex
    });
  }
}
</script>

<style scoped>
