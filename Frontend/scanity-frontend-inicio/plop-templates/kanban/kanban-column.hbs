}

.column-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0; /* Importante para que o flex funcione corretamente */
  overflow: hidden;
  padding-bottom: 10px; /* Adiciona espaço na parte inferior */
}

.cards-container {
  overflow-y: auto;
  flex: 1;
  padding-right: 4px;
  min-height: 0; /* Importante para o scroll funcionar */
  max-height: 100%; /* Garante que use todo o espaço disponível */
}

